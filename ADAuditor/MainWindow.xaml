<Window x:Class="ADAuditor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ADAuditor"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="AD_AUDITOR :: active directory recon suite"
        Height="820" Width="1280"
        Background="{StaticResource BgBrush}"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        StateChanged="Window_StateChanged"
        FontFamily="{StaticResource MonoFont}">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="34" ResizeBorderThickness="6"
                            CornerRadius="0" GlassFrameThickness="0" UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <local:SeverityToBrushConverter x:Key="SevBrush" />
    </Window.Resources>

    <Border x:Name="RootBorder" BorderBrush="#FFFF3B30" BorderThickness="1" Background="{StaticResource BgBrush}">
        <DockPanel>

            <!-- custom title bar -->
            <Border DockPanel.Dock="Top" Height="34" Background="#FF0A1410"
                    BorderBrush="{StaticResource DimGreenBrush}" BorderThickness="0,0,0,1">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,0,0">
                        <TextBlock Text="&#9608; AD_AUDITOR" FontWeight="Bold" FontSize="13"
                                   Foreground="{StaticResource GreenBrush}" />
                        <TextBlock Text="  ::  active directory recon suite" FontSize="12"
                                   Foreground="{StaticResource DimGreenBrush}" VerticalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="BtnMin" Style="{StaticResource CaptionButton}" Content="_"
                                Click="BtnMin_Click" ToolTip="Minimize" />
                        <Button x:Name="BtnMax" Style="{StaticResource CaptionButton}" Content="&#9633;"
                                Click="BtnMax_Click" ToolTip="Maximize / Restore" />
                        <Button x:Name="BtnClose" Style="{StaticResource CloseButton}" Content="&#10005;"
                                Click="BtnClose_Click" ToolTip="Close" />
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- banner -->
        <Border Grid.Row="0" BorderBrush="{StaticResource DimGreenBrush}" BorderThickness="1" Padding="10,6">
            <StackPanel>
                <TextBlock FontSize="16" FontWeight="Bold"
                           Text="+=== A D _ A U D I T O R ===========================================+" />
                <TextBlock Foreground="{StaticResource DimGreenBrush}" FontSize="12"
                           Text="  active directory security recon // authorized assessment only" />
            </StackPanel>
        </Border>

        <!-- connection bar -->
        <Border Grid.Row="1" BorderBrush="{StaticResource DimGreenBrush}" BorderThickness="1"
                Padding="10,8" Margin="0,8,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="170" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="130" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="140" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="130" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="DC/DOMAIN&gt; " VerticalAlignment="Center" />
                <TextBox x:Name="TxtServer" Grid.Column="1" VerticalAlignment="Center"
                         ToolTip="Domain DNS name (e.g. lab.local) or DC hostname. Leave empty to use the current domain." />

                <TextBlock Grid.Column="2" Text=" IP&gt; " VerticalAlignment="Center" Margin="10,0,0,0" />
                <TextBox x:Name="TxtIp" Grid.Column="3" VerticalAlignment="Center"
                         ToolTip="Optional DC IP address. If set, the LDAP connection goes straight to this IP (use when DNS does not resolve the domain)." />

                <TextBlock Grid.Column="4" Text=" USER&gt; " VerticalAlignment="Center" Margin="10,0,0,0" />
                <TextBox x:Name="TxtUser" Grid.Column="5" VerticalAlignment="Center"
                         ToolTip="DOMAIN\user. Leave empty to use current Windows credentials." />

                <TextBlock Grid.Column="6" Text=" PASS&gt; " VerticalAlignment="Center" Margin="10,0,0,0" />
                <PasswordBox x:Name="TxtPass" Grid.Column="7" VerticalAlignment="Center" />

                <Button x:Name="BtnRun" Grid.Column="9" Content="[ EXECUTE ]" Margin="10,0,6,0"
                        Click="BtnRun_Click" />
                <Button x:Name="BtnExport" Grid.Column="10" Content="[ HTML ]" Margin="0,0,6,0"
                        Click="BtnExport_Click" IsEnabled="False" />
                <Button x:Name="BtnExportCsv" Grid.Column="11" Content="[ CSV ]" Margin="0,0,6,0"
                        Click="BtnExportCsv_Click" IsEnabled="False" />
                <Button x:Name="BtnGraph" Grid.Column="12" Content="[ GRAPH ]"
                        Click="BtnGraph_Click" IsEnabled="False" />
            </Grid>
        </Border>

        <!-- score strip -->
        <ItemsControl x:Name="ScorePanel" Grid.Row="2" Margin="0,8,0,0">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
        </ItemsControl>

        <!-- main: findings + console -->
        <Grid Grid.Row="3" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="2*" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="3*" />
                    <RowDefinition Height="2*" />
                </Grid.RowDefinitions>

                <DataGrid x:Name="GridFindings" Grid.Row="0" SelectionChanged="GridFindings_SelectionChanged">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="SEV" Binding="{Binding Sev}" Width="70">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground"
                                            Value="{Binding Severity, Converter={StaticResource SevBrush}}" />
                                    <Setter Property="FontWeight" Value="Bold" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="CATEGORY" Binding="{Binding Cat}" Width="150" />
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="150" />
                        <DataGridTextColumn Header="FINDING" Binding="{Binding Title}" Width="*" />
                        <DataGridTextColumn Header="#" Binding="{Binding Count}" Width="50" />
                    </DataGrid.Columns>
                </DataGrid>

                <Border Grid.Row="1" BorderBrush="{StaticResource DimGreenBrush}" BorderThickness="1" Margin="0,6,0,0">
                    <TextBox x:Name="TxtDetails" IsReadOnly="True" BorderThickness="0"
                             Background="#FF0A1410" TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto" AcceptsReturn="True"
                             Text="// select a finding to inspect affected objects" />
                </Border>
            </Grid>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                          Background="{StaticResource DimGreenBrush}" />

            <Border Grid.Column="2" BorderBrush="{StaticResource DimGreenBrush}" BorderThickness="1">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text=" :: CONSOLE OUTPUT" Background="#FF13351F" Padding="4,2" />
                    <TextBox x:Name="TxtLog" IsReadOnly="True" BorderThickness="0"
                             Background="#FF050805" Foreground="{StaticResource GreenBrush}"
                             FontFamily="{StaticResource MonoFont}" FontSize="12"
                             TextWrapping="NoWrap" AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" />
                </DockPanel>
            </Border>
        </Grid>

        <!-- status -->
        <TextBlock x:Name="TxtStatus" Grid.Row="4" Margin="0,6,0,0"
                   Foreground="{StaticResource DimGreenBrush}" Text="STATUS: idle. awaiting target." />
            </Grid>
        </DockPanel>
    </Border>
</Window>
