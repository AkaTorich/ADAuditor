<Window x:Class="ADAuditor.GraphWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="ATTACK PATH GRAPH"
        Height="820" Width="1280"
        Background="{StaticResource BgBrush}"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="CanResize"
        StateChanged="Window_StateChanged"
        FontFamily="{StaticResource MonoFont}">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="34" ResizeBorderThickness="6"
                            CornerRadius="0" GlassFrameThickness="0" UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Border x:Name="RootBorder" BorderBrush="#FFFF3B30" BorderThickness="1" Background="{StaticResource BgBrush}">
        <DockPanel>

            <!-- custom title bar -->
            <Border DockPanel.Dock="Top" Height="34" Background="#FF0A1410"
                    BorderBrush="{StaticResource DimGreenBrush}" BorderThickness="0,0,0,1">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,0,0">
                        <TextBlock Text="&#9608; ATTACK PATH GRAPH" FontWeight="Bold" FontSize="13"
                                   Foreground="{StaticResource GreenBrush}" />
                        <TextBlock Text="  ::  tier-3 escalation map" FontSize="12"
                                   Foreground="{StaticResource DimGreenBrush}" VerticalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="BtnMin" Style="{StaticResource CaptionButton}" Content="_"
                                Click="BtnMin_Click" ToolTip="Minimize" />
                        <Button x:Name="BtnMax" Style="{StaticResource CaptionButton}" Content="&#9633;"
                                Click="BtnMax_Click" ToolTip="Maximize / Restore" />
                        <Button x:Name="BtnClose" Style="{StaticResource CloseButton}" Content="&#10005;"
                                Click="BtnClose_Click" ToolTip="Close" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- legend -->
            <Border DockPanel.Dock="Top" Background="#FF0A1410" Padding="10,6"
                    BorderBrush="{StaticResource DimGreenBrush}" BorderThickness="0,0,0,1">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text=" LEGEND: " VerticalAlignment="Center" Foreground="{StaticResource DimGreenBrush}" />
                    <Border Background="#FFFF3B30" Width="14" Height="14" Margin="6,0,3,0" />
                    <TextBlock Text="tier-0 target" VerticalAlignment="Center" Margin="0,0,12,0" />
                    <Border Background="#FFFF8C00" Width="14" Height="14" Margin="6,0,3,0" />
                    <TextBlock Text="broad principal" VerticalAlignment="Center" Margin="0,0,12,0" />
                    <Border Background="#FF33FF66" Width="14" Height="14" Margin="6,0,3,0" />
                    <TextBlock Text="entry point" VerticalAlignment="Center" Margin="0,0,12,0" />
                    <Border Background="#FF1E8F3E" Width="14" Height="14" Margin="6,0,3,0" />
                    <TextBlock Text="intermediate" VerticalAlignment="Center" Margin="0,0,18,0" />
                    <TextBlock x:Name="TxtInfo" VerticalAlignment="Center" Foreground="{StaticResource DimGreenBrush}" />
                    <TextBlock Text="   (wheel = zoom, drag = pan, dbl-click = reset)" VerticalAlignment="Center"
                               Foreground="{StaticResource DimGreenBrush}" />
                </StackPanel>
            </Border>

            <!-- pan/zoom viewport -->
            <Grid x:Name="Viewport" Background="#FF050805" ClipToBounds="True"
                  MouseWheel="Viewport_MouseWheel"
                  MouseLeftButtonDown="Viewport_MouseDown"
                  MouseLeftButtonUp="Viewport_MouseUp"
                  MouseMove="Viewport_MouseMove"
                  MouseRightButtonDown="Viewport_Reset">
                <Canvas x:Name="Cv" Background="Transparent" RenderTransformOrigin="0,0">
                    <Canvas.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform x:Name="Zoom" ScaleX="1" ScaleY="1" />
                            <TranslateTransform x:Name="Panr" X="0" Y="0" />
                        </TransformGroup>
                    </Canvas.RenderTransform>
                </Canvas>
            </Grid>

        </DockPanel>
    </Border>
</Window>
