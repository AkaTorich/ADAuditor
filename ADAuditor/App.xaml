<Application x:Class="ADAuditor.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>

            <!-- Hacker terminal palette -->
            <Color x:Key="BgColor">#FF050805</Color>
            <Color x:Key="PanelColor">#FF0A1410</Color>
            <Color x:Key="GreenColor">#FF33FF66</Color>
            <Color x:Key="DimGreenColor">#FF1E8F3E</Color>
            <Color x:Key="AmberColor">#FFFFB000</Color>
            <Color x:Key="RedColor">#FFFF3B30</Color>

            <SolidColorBrush x:Key="BgBrush" Color="{StaticResource BgColor}" />
            <SolidColorBrush x:Key="PanelBrush" Color="{StaticResource PanelColor}" />
            <SolidColorBrush x:Key="GreenBrush" Color="{StaticResource GreenColor}" />
            <SolidColorBrush x:Key="DimGreenBrush" Color="{StaticResource DimGreenColor}" />
            <SolidColorBrush x:Key="AmberBrush" Color="{StaticResource AmberColor}" />
            <SolidColorBrush x:Key="RedBrush" Color="{StaticResource RedColor}" />

            <FontFamily x:Key="MonoFont">Consolas, Lucida Console, Courier New</FontFamily>

            <!-- Base text -->
            <Style TargetType="TextBlock">
                <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
                <Setter Property="Foreground" Value="{StaticResource GreenBrush}" />
                <Setter Property="FontSize" Value="13" />
            </Style>

            <Style TargetType="Label">
                <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
                <Setter Property="Foreground" Value="{StaticResource DimGreenBrush}" />
                <Setter Property="FontSize" Value="12" />
            </Style>

            <!-- Terminal text input -->
            <Style TargetType="TextBox">
                <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
                <Setter Property="Foreground" Value="{StaticResource GreenBrush}" />
                <Setter Property="CaretBrush" Value="{StaticResource GreenBrush}" />
                <Setter Property="Background" Value="#FF0E1A12" />
                <Setter Property="BorderBrush" Value="{StaticResource DimGreenBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Padding" Value="4,3" />
                <Setter Property="FontSize" Value="13" />
            </Style>

            <Style TargetType="PasswordBox">
                <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
                <Setter Property="Foreground" Value="{StaticResource GreenBrush}" />
                <Setter Property="CaretBrush" Value="{StaticResource GreenBrush}" />
                <Setter Property="Background" Value="#FF0E1A12" />
                <Setter Property="BorderBrush" Value="{StaticResource DimGreenBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Padding" Value="4,3" />
                <Setter Property="FontSize" Value="13" />
            </Style>

            <Style TargetType="CheckBox">
                <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
                <Setter Property="Foreground" Value="{StaticResource GreenBrush}" />
            </Style>

            <!-- Terminal button: outline that inverts on hover -->
            <Style TargetType="Button">
                <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
                <Setter Property="Foreground" Value="{StaticResource GreenBrush}" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderBrush" Value="{StaticResource GreenBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Padding" Value="14,6" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="b" Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                  Margin="{TemplateBinding Padding}" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="b" Property="Background" Value="{StaticResource GreenBrush}" />
                                    <Setter Property="Foreground" Value="#FF050805" />
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Foreground" Value="{StaticResource DimGreenBrush}" />
                                    <Setter Property="Opacity" Value="0.45" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- DataGrid: dark with green grid lines -->
            <Style TargetType="DataGrid">
                <Setter Property="Background" Value="{StaticResource PanelBrush}" />
                <Setter Property="Foreground" Value="{StaticResource GreenBrush}" />
                <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="BorderBrush" Value="{StaticResource DimGreenBrush}" />
                <Setter Property="GridLinesVisibility" Value="Horizontal" />
                <Setter Property="HorizontalGridLinesBrush" Value="#FF13351F" />
                <Setter Property="RowBackground" Value="#FF0A1410" />
                <Setter Property="AlternatingRowBackground" Value="#FF0C1A12" />
                <Setter Property="HeadersVisibility" Value="Column" />
                <Setter Property="AutoGenerateColumns" Value="False" />
                <Setter Property="CanUserAddRows" Value="False" />
                <Setter Property="IsReadOnly" Value="True" />
            </Style>

            <Style TargetType="DataGridColumnHeader">
                <Setter Property="Background" Value="#FF13351F" />
                <Setter Property="Foreground" Value="{StaticResource GreenBrush}" />
                <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
                <Setter Property="FontWeight" Value="Bold" />
                <Setter Property="Padding" Value="6,4" />
                <Setter Property="BorderBrush" Value="{StaticResource DimGreenBrush}" />
                <Setter Property="BorderThickness" Value="0,0,1,1" />
            </Style>

            <Style TargetType="DataGridRow">
                <Setter Property="Foreground" Value="{StaticResource GreenBrush}" />
            </Style>

            <!-- Themed tooltip -->
            <Style TargetType="ToolTip">
                <Setter Property="Foreground" Value="{StaticResource GreenBrush}" />
                <Setter Property="Background" Value="#FF0A1410" />
                <Setter Property="BorderBrush" Value="{StaticResource DimGreenBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="Padding" Value="7,4" />
                <Setter Property="HasDropShadow" Value="False" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ToolTip">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter />
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Title-bar caption buttons (shared by all windows) -->
            <Style x:Key="CaptionButton" TargetType="Button">
                <Setter Property="Foreground" Value="{StaticResource GreenBrush}" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Width" Value="46" />
                <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
                <Setter Property="FontSize" Value="14" />
                <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="b" Background="{TemplateBinding Background}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="b" Property="Background" Value="#FF13351F" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="CloseButton" TargetType="Button" BasedOn="{StaticResource CaptionButton}">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="b" Background="{TemplateBinding Background}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="b" Property="Background" Value="#FFFF3B30" />
                                    <Setter Property="Foreground" Value="#FF050805" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ===== Custom thin terminal scrollbars ===== -->
            <Style x:Key="ScrollThumb" TargetType="Thumb">
                <Setter Property="OverridesDefaultStyle" Value="True" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Thumb">
                            <Border x:Name="t" Background="{StaticResource DimGreenBrush}"
                                    MinHeight="22" MinWidth="22" />
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="t" Property="Background" Value="{StaticResource GreenBrush}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="ScrollPageButton" TargetType="RepeatButton">
                <Setter Property="OverridesDefaultStyle" Value="True" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Focusable" Value="False" />
                <Setter Property="IsTabStop" Value="False" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="RepeatButton">
                            <Border Background="Transparent" />
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style TargetType="ScrollBar">
                <Setter Property="OverridesDefaultStyle" Value="True" />
                <Setter Property="Background" Value="#FF07120B" />
                <Setter Property="Width" Value="11" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ScrollBar">
                            <Grid x:Name="root" Background="{TemplateBinding Background}">
                                <Border BorderBrush="#FF13351F" BorderThickness="1,0,0,0" />
                                <Track x:Name="PART_Track" Orientation="{TemplateBinding Orientation}"
                                       IsDirectionReversed="True">
                                    <Track.DecreaseRepeatButton>
                                        <RepeatButton Style="{StaticResource ScrollPageButton}"
                                                      Command="ScrollBar.PageUpCommand" />
                                    </Track.DecreaseRepeatButton>
                                    <Track.Thumb>
                                        <Thumb Style="{StaticResource ScrollThumb}" />
                                    </Track.Thumb>
                                    <Track.IncreaseRepeatButton>
                                        <RepeatButton Style="{StaticResource ScrollPageButton}"
                                                      Command="ScrollBar.PageDownCommand" />
                                    </Track.IncreaseRepeatButton>
                                </Track>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="Orientation" Value="Horizontal">
                                    <Setter Property="Width" Value="Auto" />
                                    <Setter Property="Height" Value="11" />
                                    <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="False" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>
